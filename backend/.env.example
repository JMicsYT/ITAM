# ============================================================
# IT Asset Management — Backend Environment Variables
# ВАЖНО: Этот файл НЕ должен попадать в Git (добавьте в .gitignore)
# ============================================================

# --- База данных PostgreSQL ---
DATABASE_URL="postgresql://itam_user:itam_secret_password@localhost:5432/itam_db"

# --- Настройки PostgreSQL для docker-compose ---
POSTGRES_USER=itam_user
POSTGRES_PASSWORD=itam_secret_password
POSTGRES_DB=itam_db

# --- pgAdmin ---
PGADMIN_EMAIL=admin@itam.local
PGADMIN_PASSWORD=admin

# --- Сервер ---
PORT=3001
NODE_ENV=development

# --- JWT ---
# Замените на длинную случайную строку (минимум 32 символа)!
JWT_SECRET=super-secret-key-change-me-in-production-minimum-32-chars
JWT_EXPIRES=8h

# --- CORS (список разрешённых фронтенд-адресов) ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
